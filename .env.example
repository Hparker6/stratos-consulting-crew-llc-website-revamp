# Copy to .env (local) or set these in Vercel → Project → Settings → Environment Variables.
# The VITE_* vars below are all optional: each degrades to a safe default when unset.
#
# ---------------------------------------------------------------------------
# Contact form delivery (REQUIRED — the form is dead without these).
#
# These are server-side only. They are read by api/contact.ts and are NOT
# prefixed with VITE_, which means Vite never inlines them into the browser
# bundle. Do not rename them to VITE_* or the app password ships to every
# visitor who opens devtools.
#
# SMTP_PASS is a Google App Password, not the account password. Generate one at
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
#
# This file is the template that ships in git. The real values live ONLY in
# Vercel's Environment Variables (already set for production) and, for local
# work, in an untracked .env. Never paste the actual app password here — this
# file is public on GitHub, and a committed credential has to be treated as
# burned and regenerated.
#
# After changing either value in Vercel, redeploy: env vars are read at
# invocation, but an existing deployment keeps the values it was built with.
# ---------------------------------------------------------------------------
SMTP_USER=hparker6@stratosconsultingcrew.com
SMTP_PASS=xxxxxxxxxxxxxxxx

# Where submissions land. Optional; defaults to SMTP_USER.
CONTACT_TO=hparker6@stratosconsultingcrew.com

# Scheduling page for the free discovery call. Cal.com is the assumed provider,
# but any https URL works (Calendly, HubSpot Meetings, SavvyCal).
# UNSET  → every "Book a Free Call" CTA routes to the on-site /contact form.
# SET    → CTAs open the scheduler in a new tab; /contact remains as the fallback.
VITE_BOOKING_URL=https://cal.com/stratos/discovery

# Public contact address shown in the footer and on the contact page.
# UNSET  → hparker6@stratosconsultingcrew.com
VITE_CONTACT_EMAIL=hparker6@stratosconsultingcrew.com

# Company or founder LinkedIn profile.
# UNSET  → no LinkedIn link is rendered anywhere (rather than a dead placeholder).
# Also becomes the Organization schema's sameAs, so Google can connect the two.
VITE_LINKEDIN_URL=https://www.linkedin.com/in/houston-parkerr/

# ---------------------------------------------------------------------------
# Analytics. Nothing loads until the visitor accepts the consent banner.
# ---------------------------------------------------------------------------

# GA4 measurement ID. Used ONLY when no GTM container is configured.
# UNSET → falls back to the property currently in the code.
VITE_GA4_ID=G-R4XFZ4FJXC

# GTM container ID. When SET, GTM becomes the single tag layer: GA4 is then
# configured inside the container, gtag.js is NOT loaded, and every event in
# src/lib/events.ts arrives as a dataLayer event you can build triggers on.
# Leave UNSET to send straight to GA4 via gtag.js.
# The two are mutually exclusive by design — loading both would double-count
# every single event.
VITE_GTM_ID=

# Microsoft Clarity project ID (session replay + heatmaps). Optional.
VITE_CLARITY_ID=